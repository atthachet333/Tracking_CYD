# ===== Backend Environment =====
BACKEND_PORT=6678
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:6677

# ===== Google Service Account (ห้าม commit ค่าจริง) =====
GOOGLE_SHEETS_AUTH_MODE=service_account
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private Key: ครอบด้วย "..." และใช้ \n สำหรับขึ้นบรรทัดใหม่
GOOGLE_PRIVATE_KEY=

# ===== Sync: ชีตต้นทาง (อ่าน) → ปลายทาง (เขียน) =====
# ต้นทาง "อัพเดตแอดมิน" (มีแท็บ พี่คิม, แอม, ฯลฯ)
GOOGLE_SOURCE_SPREADSHEET_ID=
# ปลายทาง "ข้อมูลเว็บรวม Admin&เอกสาร" (มีแท็บ ADMIN, DOCUMENTS)
GOOGLE_TARGET_SPREADSHEET_ID=
GOOGLE_TARGET_ADMIN_SHEET=ADMIN
GOOGLE_TARGET_DOCUMENTS_SHEET=DOCUMENTS

# ===== (legacy) Dashboard endpoints เดิม — ถ้าว่างจะใช้ source id =====
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_GID=0
GOOGLE_SHEETS_DEFAULT_RANGE=A:ZZ
GOOGLE_SHEETS_CACHE_TTL_SECONDS=60
GOOGLE_SHEETS_TIMEOUT_MS=15000
