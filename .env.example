# Frontend
FRONTEND_PORT=6677
VITE_API_BASE_URL=/api

# Backend
NODE_ENV=development
BACKEND_PORT=6678
FRONTEND_ORIGIN=http://localhost:6677

# Google Sheets sync
GOOGLE_SOURCE_SPREADSHEET_ID=
GOOGLE_TARGET_SPREADSHEET_ID=
GOOGLE_TARGET_ADMIN_SHEET=ADMIN
GOOGLE_TARGET_DOCUMENTS_SHEET=DOCUMENTS
GOOGLE_TARGET_SUMMARY_SHEET=SUMMARY

# Google Sheets dashboard fallback
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_GID=0
GOOGLE_SHEETS_DEFAULT_RANGE=A:ZZ
GOOGLE_SHEETS_CACHE_TTL_SECONDS=60
GOOGLE_SHEETS_TIMEOUT_MS=15000
GOOGLE_SHEETS_AUTH_MODE=service_account

# Customer dashboard (ภาพรวมลูกค้าและสถานะเคส)
# gid ต้นทางสำหรับ traceability (แท็บนี้อาจไม่มีคอลัมน์สถานะลูกค้า ระบบจะ fallback ไปแท็บผู้รับผิดชอบที่มี header จริง)
CUSTOMER_DASHBOARD_SOURCE_GID=1532373081
CUSTOMER_DASHBOARD_STATUS_HEADER=สถานะลูกค้า
CUSTOMER_DASHBOARD_CACHE_TTL_SECONDS=45

# Documents dashboard (แท็บ DOCUMENTS ในชีตปลายทาง)
DOCUMENTS_DASHBOARD_GID=1341336506
DOCUMENTS_DASHBOARD_CACHE_TTL_SECONDS=45

# Service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
